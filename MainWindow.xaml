<Window x:Class="MyMoney.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="600" Width="1000">
    <Grid Background="#F5F5F5" Margin="20">
        <Grid Background="#F5F5F5" Margin="10">

            <!-- Tiêu đề góc trái -->
            <StackPanel Orientation="Vertical"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="10,10,0,0">
                <TextBlock Text="Quản lý Chi tiêu"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#333"/>
                <TextBlock Text="Theo dõi thu chi cá nhân của bạn"
                           FontSize="16"
                           Foreground="#666"
                           Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Các ô giao diện nằm ngang -->
            <Grid Margin="0,79,0,0">
                <!-- đẩy xuống dưới tiêu đề -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Ô 1: Thu nhập -->
                <Border Grid.Column="0" Background="White" CornerRadius="10" Margin="10,10,10,322" Padding="20">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Thu nhập tháng này" FontSize="16" FontWeight="Bold" Foreground="#333"/>
                            <TextBlock x:Name="txtThuNhap" Text="0₫" FontSize="24" FontWeight="SemiBold" Foreground="#4CAF50"/>
                        </StackPanel>
                        <!-- Icon -->
                        <TextBlock Text="&#xE8C7;" 
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="20"
                                   Foreground="#4CAF50"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Top"/>
                    </Grid>
                </Border>

                <!-- Ô 2: Chi tiêu -->
                <Border Grid.Column="1" Background="White" CornerRadius="10" Margin="10,10,10,322" Padding="20">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Chi tiêu tháng này" FontSize="16" FontWeight="Bold" Foreground="#333"/>
                            <TextBlock x:Name="txtChiTieu" Text="0₫" FontSize="24" FontWeight="SemiBold" Foreground="#F44336"/>
                        </StackPanel>
                        <!-- Icon -->
                        <TextBlock Text="&#xE719;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="20"
                                   Foreground="#F44336"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Top"/>
                    </Grid>
                </Border>

                <!-- Ô 3: Số dư -->
                <Border Grid.Column="2" Background="White" CornerRadius="10" Margin="10,10,10,322" Padding="20">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Số dư hiện tại" FontSize="16" FontWeight="Bold" Foreground="#333"/>
                            <TextBlock x:Name="txtSoDu" Text="0₫" FontSize="24" FontWeight="SemiBold" Foreground="#2196F3"/>
                        </StackPanel>
                        <!-- Icon -->
                        <TextBlock Text="&#xE72D;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="20"
                                   Foreground="#2196F3"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Top"/>
                    </Grid>
                </Border>

                <!-- Ô 4: Tỷ lệ tiết kiệm -->
                <Border Grid.Column="3" Background="White" CornerRadius="10" Margin="10,10,10,322" Padding="20">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Tỷ lệ tiết kiệm" FontSize="16" FontWeight="Bold" Foreground="#333"/>
                            <TextBlock x:Name="txtTiLeTietKiem" Text="0.0%" FontSize="24" FontWeight="SemiBold" Foreground="#FF9800"/>
                        </StackPanel>
                        <!-- Icon -->
                        <TextBlock Text="&#xE870;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="20"
                                   Foreground="#FF9800"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Top"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
